# Minimal dev env (bot only)
DISCORD_TOKEN=
MAMACORD_STORAGE_BACKEND=postgres
MAMACORD_POSTGRES_DSN=postgres://mamacord:secret@127.0.0.1:5432/mamacord?sslmode=disable

# Optional: runtime roles.
# Default is control,gateway,scheduler.
# API-only local control plane:
# MAMACORD_RUNTIME_ROLES=control
# Bot + scheduler without dashboard:
# MAMACORD_RUNTIME_ROLES=gateway,scheduler
# Bot ingress only:
# MAMACORD_RUNTIME_ROLES=gateway
# Scheduler only:
# MAMACORD_RUNTIME_ROLES=scheduler

# Optional: speed up command iteration by registering commands to one guild only.
# DISCORD_DEV_GUILD_ID=123456789012345678

# Optional: enable the admin API (dashboard backend). `mamacord dev` defaults this
# to 127.0.0.1:8081 if unset.
# MAMACORD_ADMIN_ADDR=127.0.0.1:8081

# Optional: enable Discord OAuth sign-in for the dashboard.
# Discord Developer Portal -> OAuth2.
# MAMACORD_DASHBOARD_CLIENT_ID=
# MAMACORD_DASHBOARD_CLIENT_SECRET=

# Optional: fallback if Discord owner lookup fails (rare).
# OWNER_USER_ID=123456789012345678
