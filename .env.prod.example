# Minimal production env
DISCORD_TOKEN=

MAMACORD_PROD_MODE=1
MAMACORD_ALLOW_UNSIGNED_PLUGINS=0

# Bundled official plugins are already signed.
# Default trusted public keys live here:
# MAMACORD_TRUSTED_KEYS_FILE=./config/trusted_keys.json
#
# If you want to sign your own plugins, generate a signer:
# go run ./cmd/mamacord gen-signing-key --key-id your-key-id
#
# Optional: let the dashboard sign scaffolded plugins with that same key:
# MAMACORD_DASHBOARD_SIGNING_KEY_ID=your-key-id
# MAMACORD_DASHBOARD_SIGNING_KEY_FILE=./data/keys/your-key-id.key

# Optional: storage location override
# SQLITE_PATH=./data/mamacord.sqlite

# Optional: enable admin API (dashboard backend).
# If enabled in prod mode, OAuth + session config MUST be complete.
# MAMACORD_ADMIN_ADDR=0.0.0.0:8081
# MAMACORD_DASHBOARD_CLIENT_ID=
# MAMACORD_DASHBOARD_CLIENT_SECRET=
# MAMACORD_DASHBOARD_SESSION_SECRET=change-me-change-me-change-me-change-me
#
# GitHub Pages + API subdomain hosting:
# MAMACORD_PUBLIC_DASHBOARD_ORIGIN=https://example.com
# MAMACORD_PUBLIC_API_ORIGIN=https://api.example.com
# MAMACORD_DASHBOARD_ALLOWED_ORIGINS=https://example.com

# Optional: fallback if Discord owner lookup fails (rare).
# OWNER_USER_ID=123456789012345678
