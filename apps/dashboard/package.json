{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "mamacord-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "build": "tsc --noEmit && vite build --mode prod",
    "preview": "vite preview",
    "typecheck": "bunx tsc --noEmit",
    "biome:check": "bunx biome check . --write --max-diagnostics 16384",
    "biome:format": "bunx biome format . --write --max-diagnostics 16384",
    "biome:lint": "bunx biome lint . --write --max-diagnostics 16384"
  },
  "dependencies": {
    "@mantine/core": "^9.2.1",
    "@mantine/hooks": "^9.2.1",
    "@mantine/notifications": "^9.2.1",
    "@mamacord/web-ui": "workspace:*",
    "@tabler/icons-react": "^3.44.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
